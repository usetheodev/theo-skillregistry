{
  "name": "@usetheo/skillregistry-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "theoskill": "./dist/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' --no-error-on-unmatched-pattern",
    "test": "vitest run --config vitest.contract.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@usetheo/skillregistry": "workspace:*",
    "@usetheo/skillregistry-api": "workspace:*",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/yazl": "^2.4.5",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
